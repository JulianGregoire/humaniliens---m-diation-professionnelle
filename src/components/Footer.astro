---
import Logo from './Logo.astro';

const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-900 text-slate-400 py-12 border-t border-slate-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-4 gap-8 mb-8">
      <div class="col-span-1 md:col-span-2">
        <a 
          href="/"
          class="mb-4 grayscale brightness-200 opacity-80 hover:opacity-100 transition-opacity inline-block"
        >
            <Logo />
        </a>
        <p class="text-sm max-w-xs">
          Médiation professionnelle pour les entreprises. Restaurer le dialogue, sécuriser les relations, construire l'avenir.
        </p>
      </div>
      
      <div>
        <h4 class="text-white font-semibold mb-4">Navigation</h4>
        <ul class="space-y-2 text-sm">
          <li>
            <a 
              href="/#home" 
              class="hover:text-white transition-colors"
            >
              Accueil
            </a>
          </li>
          <li>
            <a 
              href="/#about" 
              class="hover:text-white transition-colors"
            >
              À propos
            </a>
          </li>
          <li>
            <a 
              href="/#services" 
              class="hover:text-white transition-colors"
            >
              Services
            </a>
          </li>
          <li>
            <a 
              href="/#contact" 
              class="hover:text-white transition-colors"
            >
              Contact
            </a>
          </li>
          <li>
            <a 
              href="/blog" 
              class="hover:text-white transition-colors"
            >
              Blog
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-4">Légal</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/mentions-legales" class="hover:text-white transition-colors">Mentions Légales</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Politique de confidentialité</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Code de déontologie</a></li>
        </ul>
      </div>
    </div>
    
    <div class="pt-8 border-t border-slate-800 flex flex-col md:flex-row justify-between items-center text-xs">
      <div class="flex flex-col gap-1">
        <p>&copy; {currentYear} HumaniLiens. Tous droits réservés.</p>
        <p class="text-blue-400 font-medium">Disponible en Métropole & DOM/TOM</p>
      </div>
      <p class="mt-2 md:mt-0">Marie-Andrée SAUVEUR-FONTAIN - EI</p>
    </div>
  </div>
</footer>

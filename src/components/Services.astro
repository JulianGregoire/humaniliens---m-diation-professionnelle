---
import { SERVICES } from '../constants.ts';
---

<section id="services" class="py-24 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="text-blue-600 font-semibold tracking-wider uppercase text-sm">Mes expertises</span>
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mt-2 mb-4">Domaines d'intervention</h2>
      <p class="text-slate-600 max-w-2xl mx-auto">
        Chaque situation est unique. J'adapte le processus de médiation à la nature de votre structure et à la typologie du conflit.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {SERVICES.map((service) => (
        <div 
          class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group border border-slate-100"
        >
          <div class="w-14 h-14 bg-blue-50 rounded-xl flex items-center justify-center text-blue-600 mb-6 group-hover:bg-blue-600 group-hover:text-white transition-colors">
            <service.icon size={28} strokeWidth={1.5} />
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">{service.title}</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            {service.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

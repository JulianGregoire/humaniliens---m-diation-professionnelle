---
import { SERVICES } from '../constants.ts';
---

<section id="services" class="py-24 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="text-blue-600 font-semibold tracking-wider uppercase text-sm">Mes expertises</span>
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mt-2 mb-4">Activités & Accompagnement</h2>
      <p class="text-slate-600 max-w-2xl mx-auto">
        Professionnelle de la relation et de la communication, j'adapte mon expertise à votre contexte, que vous soyez un particulier ou une organisation.
      </p>
    </div>

    {/* Section Particuliers */}
    <div class="mb-20">
      <div class="flex items-center gap-4 mb-10">
        <div class="h-px bg-slate-200 flex-grow"></div>
        <h3 class="text-2xl font-bold text-slate-800 uppercase tracking-tight">Aux Particuliers</h3>
        <div class="h-px bg-slate-200 flex-grow"></div>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {SERVICES.filter(s => s.category === 'particulier').map((service) => (
          <div 
            class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group border border-slate-100"
          >
            <div class="w-14 h-14 bg-blue-50 rounded-xl flex items-center justify-center text-blue-600 mb-6 group-hover:bg-blue-600 group-hover:text-white transition-colors">
              <service.icon size={28} strokeWidth={1.5} />
            </div>
            <h4 class="text-xl font-bold text-slate-900 mb-3">{service.title}</h4>
            <p class="text-slate-600 text-sm leading-relaxed">
              {service.description}
            </p>
          </div>
        ))}
      </div>
    </div>

    {/* Section Entreprises */}
    <div>
      <div class="flex items-center gap-4 mb-10">
        <div class="h-px bg-slate-200 flex-grow"></div>
        <h3 class="text-2xl font-bold text-slate-800 uppercase tracking-tight">Aux Entreprises</h3>
        <div class="h-px bg-slate-200 flex-grow"></div>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        {SERVICES.filter(s => s.category === 'entreprise').map((service) => (
          <div 
            class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group border border-slate-100"
          >
            <div class="flex flex-col h-full">
              <div class="flex items-start gap-6 mb-6">
                <div class="w-14 h-14 bg-blue-50 rounded-xl flex-shrink-0 flex items-center justify-center text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-colors">
                  <service.icon size={28} strokeWidth={1.5} />
                </div>
                <div>
                  <h4 class="text-xl font-bold text-slate-900 mb-2">{service.title}</h4>
                  <p class="text-slate-600 text-sm leading-relaxed">
                    {service.description}
                  </p>
                </div>
              </div>
              
              {service.subItems && (
                <ul class="mt-auto space-y-3">
                  {service.subItems.map(item => (
                    <li class="flex items-start gap-3 text-sm text-slate-600">
                      <span class="text-blue-500 mt-1">•</span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        ))}
      </div>
      <p class="text-center text-slate-500 italic mt-12 text-sm">
        Entreprises de tous secteurs et tailles confondus : comment concilier votre ambition de croissance et votre performance humaine ?
      </p>
    </div>
  </div>
</section>

---
import { ArrowRight, CheckCircle2 } from 'lucide-react';
---

<section id="home" class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden bg-gradient-to-b from-blue-50/50 to-white">
  {/* Background decoration */}
  <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 bg-sky-200 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-blob"></div>
  <div class="absolute top-0 left-0 -ml-20 -mt-20 w-96 h-96 bg-blue-200 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-blob animation-delay-2000"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="space-y-8">

        <h1 class="text-4xl lg:text-6xl font-bold text-slate-900 leading-tight">
          Anticiper les blocages, transformer les <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-sky-500">tensions</span> en dialogue.
        </h1>
        
        <p class="text-lg text-slate-600 max-w-xl">
          Marie-Andrée Fontaine, médiateure certifiée. J'interviens en anticipation et en prévention pour préserver la qualité relationnelle et dénouer les situations de blocage entre collaborateurs ou avec la direction.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#contact" class="inline-flex justify-center items-center px-6 py-3.5 bg-blue-800 text-white font-semibold rounded-lg hover:bg-blue-900 transition-all shadow-lg hover:shadow-blue-800/30 group">
            Demander une médiation
            <ArrowRight class="ml-2 w-4 h-4 group-hover:translate-x-1 transition-transform" />
          </a>
          <a href="#services" class="inline-flex justify-center items-center px-6 py-3.5 bg-white text-slate-700 border border-slate-200 font-semibold rounded-lg hover:bg-slate-50 transition-all">
            Découvrir mes services
          </a>
        </div>

        <div class="pt-4 flex flex-wrap items-center gap-6 text-sm text-slate-500">
          <div class="flex items-center gap-2">
            <CheckCircle2 class="w-5 h-5 text-blue-500" />
            <span>Neutralité</span>
          </div>
          <div class="flex items-center gap-2">
            <CheckCircle2 class="w-5 h-5 text-blue-500" />
            <span>Indépendance</span>
          </div>
          <div class="flex items-center gap-2">
            <CheckCircle2 class="w-5 h-5 text-blue-500" />
            <span>Impartialité</span>
          </div>
        </div>
      </div>

      <div class="relative lg:h-[600px] flex items-center justify-center">
        {/* Image Placeholder - Represents Professionalism and Connection */}
        <div class="relative w-full max-w-md aspect-[4/5] rounded-2xl overflow-hidden shadow-2xl">
          <img 
            src="https://images.unsplash.com/photo-1573497620053-ea5300f94f21?q=80&w=2070&auto=format&fit=crop" 
            alt="Médiation professionnelle" 
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-blue-900/60 to-transparent"></div>
          <div class="absolute bottom-6 left-6 right-6 text-white">
            <blockquote class="text-lg font-medium italic mb-2">
              "Au-delà du désaccord, il y a toujours un terrain d'entente à construire."
            </blockquote>
            <p class="text-sm text-blue-100 font-semibold">— Marie-Andrée Fontaine</p>
          </div>
        </div>
        
        {/* Floating Badge */}
        <div class="absolute top-10 -right-4 bg-white p-4 rounded-xl shadow-xl max-w-[220px] border-l-4 border-blue-500 hidden md:block">
          <p class="text-xs font-bold text-slate-400 uppercase tracking-wide mb-1">Expertise</p>
          <p class="text-sm font-semibold text-slate-800">Certifiée de l'EPMN (Bordeaux)</p>
        </div>
      </div>
    </div>
  </div>
</section>

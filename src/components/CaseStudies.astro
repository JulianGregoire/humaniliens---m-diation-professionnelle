---
import { CASE_STUDIES } from '../constants.ts';
import { Lock } from 'lucide-react';
---

<section id="cases" class="py-24 bg-white relative overflow-hidden">
    {/* Decorative background element */}
  <div class="absolute left-0 bottom-0 w-full h-1/2 bg-slate-50 -skew-y-3 z-0"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
      <div class="max-w-2xl">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Cas Concrets de Médiation</h2>
        <p class="text-slate-600">
          Pour mieux comprendre l'impact de la médiation, voici quelques exemples d'interventions réalisées.
          <br/>
          <span class="flex items-center gap-1 text-sm font-medium text-blue-600 mt-2">
            <Lock size={14} /> Respect strict de l'anonymat et du secret professionnel
          </span>
        </p>
      </div>
    </div>

    <div class="grid lg:grid-cols-3 gap-8">
      {CASE_STUDIES.map((study) => (
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-slate-100 flex flex-col h-full">
          <div class="mb-6">
            <span class="inline-block px-3 py-1 bg-sky-100 text-sky-800 text-xs font-semibold rounded-full mb-3">
              {study.sector}
            </span>
            <h3 class="text-xl font-bold text-slate-900">{study.title}</h3>
          </div>
          
          <div class="space-y-4 flex-grow">
            <div>
              <h4 class="text-sm font-bold text-slate-400 uppercase tracking-wide mb-1">La Situation</h4>
              <p class="text-slate-700 text-sm">{study.context}</p>
            </div>
            <div>
              <h4 class="text-sm font-bold text-slate-400 uppercase tracking-wide mb-1">L'Intervention</h4>
              <p class="text-slate-700 text-sm">{study.intervention}</p>
            </div>
            <div class="pt-4 mt-4 border-t border-slate-100">
               <h4 class="text-sm font-bold text-blue-600 uppercase tracking-wide mb-1">Le Résultat</h4>
               <p class="text-slate-800 font-medium">{study.outcome}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

---
import Layout from '../../layouts/Layout.astro';
import { Calendar, ArrowLeft, Clock } from 'lucide-react';
import { BLOG_POSTS } from '../../constants.ts';

export function getStaticPaths() {
  return BLOG_POSTS.map((post) => ({
    params: { id: post.id.toString() },
    props: { post },
  }));
}

const { post } = Astro.props;

// Basic reading time estimation
const wordCount = post.content.split(/\s+/).length;
const readingTime = Math.ceil(wordCount / 200);
---

<Layout title={`${post.title} | HumaniLiens`} description={post.excerpt}>
  <article class="pt-32 pb-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/blog" class="inline-flex items-center text-blue-600 hover:text-blue-800 transition-colors mb-8 group">
        <ArrowLeft class="mr-2 w-4 h-4 group-hover:-translate-x-1 transition-transform" />
        Tous les articles
      </a>

      <header class="mb-12">
        <div class="flex items-center gap-4 text-sm font-medium text-blue-600 mb-4">
          <span class="px-3 py-1 bg-blue-50 rounded-full">{post.category}</span>
          <div class="flex items-center gap-1.5 text-slate-400">
            <Calendar size={14} />
            <span>{post.date}</span>
          </div>
          <div class="flex items-center gap-1.5 text-slate-400">
            <Clock size={14} />
            <span>{readingTime} min de lecture</span>
          </div>
        </div>
        <h1 class="text-3xl md:text-5xl font-bold text-slate-900 leading-tight mb-8">
          {post.title}
        </h1>
        <div class="aspect-video rounded-3xl overflow-hidden shadow-xl mb-12">
          <img 
            src={post.image} 
            alt={post.title} 
            class="w-full h-full object-cover"
            referrerPolicy="no-referrer"
          />
        </div>
      </header>

      <div class="prose prose-lg prose-slate max-w-none prose-headings:text-slate-900 prose-p:text-slate-600 prose-strong:text-slate-900 prose-img:rounded-3xl">
        {/* Simple markdown-to-html conversion for content (since we already have a basic structure in constants) */}
        <div class="whitespace-pre-line text-slate-600 leading-relaxed text-lg">
          {post.content}
        </div>
      </div>

      <div class="mt-16 pt-16 border-t border-slate-100">
        <div class="bg-blue-50 rounded-3xl p-8 md:p-12 flex flex-col md:flex-row items-center gap-8">
          <div class="flex-grow text-center md:text-left">
            <h3 class="text-2xl font-bold text-slate-900 mb-2">Cet article vous a intéressé ?</h3>
            <p class="text-slate-600">Partagez-le ou contactez-moi pour discuter de votre situation.</p>
          </div>
          <a href="/#contact" class="flex-shrink-0 px-8 py-4 bg-blue-600 text-white font-bold rounded-full hover:bg-blue-700 transition-all shadow-lg shadow-blue-600/20">
            Prendre contact
          </a>
        </div>
      </div>
    </div>
  </article>
</Layout>
